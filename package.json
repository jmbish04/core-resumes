{
  "name": "core-resumes",
  "version": "26.02.24",
  "description": "The template helps you build apps with Astro, Tailwind CSS, and shadcn/ui.",
  "license": "MIT",
  "author": {
    "name": "126colby",
    "url": "https://github.com/126colby"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jmbish04/core-resumes"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "wrangler dev",
    "start": "astro dev",
    "fmt": "oxfmt",
    "lint": "oxlint",
    "check": "oxlint && oxfmt",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "migrate:local": "pnpm run db:generate && wrangler d1 migrations apply DB --local",
    "migrate:remote": "pnpm run db:generate && wrangler d1 migrations apply DB --remote",
    "seed:local": "wrangler d1 execute DB --local --file=src/backend/db/seeds/seed.sql",
    "seed:remote": "wrangler d1 execute DB --remote --file=src/backend/db/seeds/seed.sql",
    "seed:rubrics:local": "wrangler d1 execute DB --local --file=src/backend/db/seeds/seed-rubrics.sql",
    "seed:rubrics:remote": "wrangler d1 execute DB --remote --file=src/backend/db/seeds/seed-rubrics.sql",
    "seed:global-config:local": "wrangler d1 execute DB --local --file=src/backend/db/seeds/seed-global-config.sql",
    "seed:global-config:remote": "wrangler d1 execute DB --remote --file=src/backend/db/seeds/seed-global-config.sql",
    "seed:resume-bullets:local": "wrangler d1 execute DB --local --file=src/backend/db/seeds/seed-resume-bullets.sql",
    "seed:resume-bullets:remote": "wrangler d1 execute DB --remote --file=src/backend/db/seeds/seed-resume-bullets.sql",
    "seed:all:local": "pnpm run seed:local && pnpm run seed:rubrics:local && pnpm run seed:global-config:local && pnpm run seed:resume-bullets:local",
    "seed:all:remote": "pnpm run seed:remote && pnpm run seed:rubrics:remote && pnpm run seed:global-config:remote && pnpm run seed:resume-bullets:remote",
    "deploy": "pnpm run verify-sandbox && pnpm run build && cp .assetsignore dist/.assetsignore && pnpm run migrate:remote && wrangler deploy",
    "deploy:preview": "pnpm run verify-sandbox && pnpm run build && cp .assetsignore dist/.assetsignore && wrangler deploy --env preview",
    "deploy:tail": "pnpm run deploy && pnpm run tail",
    "verify-sandbox": "node scripts/verify-sandbox-version.mjs",
    "session:sync": "scripts/.venv/bin/python3 scripts/sync-cookies.py",
    "cf-typegen": "wrangler types --include-runtime false",
    "types": "pnpm run cf-typegen && tsc --noEmit",
    "tail": "rm -f wrangler.log && wrangler tail | tee wrangler.log"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.179",
    "@anthropic-ai/sdk": "latest",
    "@assistant-ui/react": "^0.14.0",
    "@assistant-ui/react-ai-sdk": "^1.3.23",
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "^12.6.13",
    "@astrojs/react": "^4.4.2",
    "@base-ui/react": "^1.4.1",
    "@cloudflare/ai-chat": "^0.7.0",
    "@cloudflare/sandbox": "^0.10.2",
    "@cloudflare/workers-types": "^4.20260510.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@google/genai": "latest",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.4.0",
    "@hono/zod-validator": "^0.7.6",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openai/agents": "^0.8.5",
    "@platejs/basic-nodes": "^53.0.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-pdf/renderer": "latest",
    "@scalar/hono-api-reference": "^0.10.14",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "agents": "^0.11.9",
    "ai": "^6.0.177",
    "astro": "^5.18.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.12.18",
    "lucide-react": "^0.575.0",
    "maplibre-gl": "^5.24.0",
    "mimetext": "^3.0.28",
    "mustache": "^4.2.0",
    "notebooklm-sdk": "^0.3.4",
    "openai": "latest",
    "platejs": "^53.0.3",
    "postal-mime": "^2.7.4",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.11.0",
    "recharts": "^3.8.1",
    "shadcn": "^4.7.0",
    "slate": "^0.124.1",
    "slate-history": "^0.113.1",
    "slate-react": "^0.124.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "workers-ai-provider": "^3.1.14",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/playwright": "^1.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/mustache": "^4.2.6",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "better-sqlite3": "^11.10.0",
    "drizzle-kit": "^0.31.10",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.63.0",
    "playwright": "^1.59.1",
    "typescript": "^5.9.3",
    "wrangler": "^4.90.0"
  },
  "pnpm": {
    "overrides": {
      "vite": "6.4.2",
      "@cloudflare/workers-types": "^4.20260502.1",
      "drizzle-orm": "^0.45.2"
    },
    "onlyBuiltDependencies": [
      "@google/genai",
      "esbuild",
      "msw",
      "protobufjs",
      "sharp",
      "workerd"
    ]
  }
}
