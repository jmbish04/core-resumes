---
import { eq } from "drizzle-orm";
import { getDb } from "@/backend/db";
import { roles } from "@/backend/db/schema";
import { RoleHeader } from "@/components/role/RoleHeader";
import { RoleViewport } from "@/components/role/RoleViewport";
import { Sidebar } from "@/components/Sidebar";
import BaseLayout from "@/layouts/BaseLayout.astro";

if (!Astro.cookies.has("cr_session")) {
  return Astro.redirect("/login");
}

const { id } = Astro.params;
const db = getDb(Astro.locals.runtime.env);
const [role] = await db.select().from(roles).where(eq(roles.id, id!)).limit(1);

if (!role) {
  return new Response("Role not found", { status: 404 });
}
---

<BaseLayout title={`${role.companyName} | Career Orchestrator`} description={role.jobTitle}>
  <div class="flex flex-1">
    <Sidebar client:load />
    <section class="min-w-0 flex-1">
      <div class="mx-auto grid w-full max-w-screen-2xl gap-5 px-4 py-5 lg:px-8">
        <RoleHeader role={role} client:load />
        <RoleViewport role={role} client:load />
      </div>
    </section>
  </div>
</BaseLayout>
