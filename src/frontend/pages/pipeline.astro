---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Sidebar } from "@/components/Sidebar";
import { PipelineOperations } from "@/components/pipeline/PipelineOperations";
---

<BaseLayout title="Pipeline Operations | Colby" description="Monitor and review GitHub Action sync runs that aggregate job board data into D1.">
  <div class="flex flex-1 relative w-full">
    {/* Always render the main Sidebar */}
    <Sidebar client:load />
    
    {/* Full-page responsive main section */}
    <section class="min-w-0 flex-1 w-full">
      <div class="mx-auto w-full gap-6 px-4 py-6 lg:px-8">
        <PipelineOperations client:only="react" />
      </div>
    </section>
  </div>
</BaseLayout>
