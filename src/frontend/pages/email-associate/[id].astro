---
import { EmailAssociate } from "@/components/role/EmailAssociate";
import { Sidebar } from "@/components/Sidebar";
import BaseLayout from "@/layouts/BaseLayout.astro";

if (!Astro.cookies.has("cr_session")) {
  return Astro.redirect("/login");
}

const { id } = Astro.params;
const response = await fetch(new URL(`/api/emails/${id}`, Astro.request.url), {
  headers: { cookie: Astro.request.headers.get("cookie") ?? "" },
});

if (response.status === 404) {
  return new Response("Email not found", { status: 404 });
}

const email = await response.json();
---

<BaseLayout title="Associate Email | Career Orchestrator" description="Map an inbound email to a role.">
  <div class="flex flex-1">
    <Sidebar client:load />
    <section class="min-w-0 flex-1">
      <div class="mx-auto grid w-full max-w-screen-2xl gap-5 px-4 py-5 lg:px-8">
        <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <h1 class="text-2xl font-semibold tracking-tight">Email Association</h1>
            <p class="mt-1 text-sm text-muted-foreground">Attach the inbound message to a tracked role.</p>
          </div>
          <a class="text-sm text-muted-foreground hover:text-foreground" href="/">Back to dashboard</a>
        </div>
        <EmailAssociate email={email} client:load />
      </div>
    </section>
  </div>
</BaseLayout>
