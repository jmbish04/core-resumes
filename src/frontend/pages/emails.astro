---
import { EmailsPage } from "@/components/email/EmailsPage";
import { Sidebar } from "@/components/Sidebar";
import BaseLayout from "@/layouts/BaseLayout.astro";

if (!Astro.cookies.has("cr_session")) {
  return Astro.redirect("/login");
}
---

<BaseLayout title="Emails | Career Orchestrator" description="Global inbox for all inbound recruiting emails.">
  <div class="flex flex-1">
    <Sidebar client:load />
    <section class="min-w-0 flex-1">
      <div class="mx-auto w-full max-w-screen-2xl px-4 py-5 lg:px-8">
        <EmailsPage client:load />
      </div>
    </section>
  </div>
</BaseLayout>
