---

import { JobsByCompanyChart } from "@/components/dashboard/JobsByCompanyChart";
import { PendingTasks } from "@/components/dashboard/PendingTasks";
import { PreparingList } from "@/components/dashboard/PreparingList";
import { RecentEmails } from "@/components/dashboard/RecentEmails";
import { SalaryRangeChart } from "@/components/dashboard/SalaryRangeChart";
import { MarketSalaryStatsCard } from "@/components/dashboard/MarketSalaryStatsCard";
import { StatCards } from "@/components/dashboard/StatCards";
import { IntakeModal } from "@/components/intake/IntakeModal";
import { Sidebar } from "@/components/Sidebar";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteConfig } from "@/lib/config";

if (!Astro.cookies.has("cr_session")) {
  return Astro.redirect("/login");
}
---

<BaseLayout title={`${siteConfig.name} | Dashboard`} description={siteConfig.description}>
  <div class="flex flex-1">
    <Sidebar client:load />
    <section class="min-w-0 flex-1">
      <div class="mx-auto grid w-full max-w-screen-2xl gap-5 px-4 py-5 lg:px-8">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <h1 class="text-2xl font-semibold tracking-tight">Dashboard</h1>
            <p class="mt-1 text-sm text-muted-foreground">
              Role pipeline, Colby task activity, and inbound email routing.
            </p>
          </div>
        </div>

        <StatCards client:load />

        <div class="grid gap-5 lg:grid-cols-3">
          <JobsByCompanyChart client:load />
          <SalaryRangeChart client:load />
          <MarketSalaryStatsCard client:load />
        </div>


        <div class="grid gap-5 xl:grid-cols-3">
          <PreparingList client:load />
          <PendingTasks client:load />
          <RecentEmails client:load />
        </div>
      </div>
    </section>
    <IntakeModal client:load />
  </div>
</BaseLayout>
