---
import { ConfigTabs } from "@/components/config/ConfigTabs";
import { Sidebar } from "@/components/Sidebar";
import BaseLayout from "@/layouts/BaseLayout.astro";

if (!Astro.cookies.has("cr_session")) {
  return Astro.redirect("/login");
}
---

<BaseLayout title="Config | Career Orchestrator" description="Global Colby configuration.">
  <div class="flex flex-1">
    <Sidebar client:load />
    <section class="min-w-0 flex-1">
      <div class="mx-auto grid w-full max-w-screen-2xl gap-5 px-4 py-5 lg:px-8">
        <div>
          <h1 class="text-2xl font-semibold tracking-tight">Config</h1>
          <p class="mt-1 text-sm text-muted-foreground">Global rules and document source data used by Colby.</p>
        </div>
        <ConfigTabs client:only="react" />
      </div>
    </section>
  </div>
</BaseLayout>
